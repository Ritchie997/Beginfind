# Порт для сервера
PORT=3002

# Хост для сервера
HOST=0.0.0.0

# Root пользователь (администратор)
# Используйте ROOT_USERNAME (не ROOT_EMAIL) для имени пользователя
ROOT_USERNAME=root
ROOT_PASSWORD=ваш_пароль_здесь

# Секретный ключ для JWT токенов (рекомендуется изменить на случайную строку)
JWT_SECRET=default_secret
