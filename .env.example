# Пример файла переменных окружения для BeginFind Server
# Скопируйте этот файл в .env и настройте под себя

# Порт для сервера
PORT=3002

# Хост для сервера
# Для локальной разработки: localhost (сервер доступен только с этого компьютера)
# Для доступа из локальной сети: 0.0.0.0 (сервер доступен с других устройств в сети)
# Для Render.com и других облачных платформ: 0.0.0.0
HOST=0.0.0.0

# ========================================
# БЕЗОПАСНОСТЬ И АВТОРИЗАЦИЯ
# ========================================

# Секретный ключ для JWT токенов (СГЕНЕРИРУЙТЕ СЛУЧАЙНУЮ СТРОКУ!)
# Рекомендуется использовать: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Время жизни access токена
JWT_EXPIRES_IN=8h

# Время жизни refresh токена
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# ROOT-АККАУНТ (создаётся через node create-root-account.js)
# ========================================

# Имя root-пользователя (логин для входа)
ROOT_USERNAME=

# Пароль root-пользователя (минимум 6 символов)
# ВАЖНО: После создания root-аккаунта рекомендуется удалить или закомментировать эту строку
ROOT_PASSWORD=