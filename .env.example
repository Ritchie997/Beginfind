# Пример файла переменных окружения для BeginFind Server
# Скопируйте этот файл в .env и настройте под себя

# Порт для сервера
PORT=3002

# Хост для сервера
# Для локальной разработки: localhost (сервер доступен только с этого компьютера)
# Для доступа из локальной сети: 0.0.0.0 (сервер доступен с других устройств в сети)
# Для Render.com и других облачных платформ: 0.0.0.0
HOST=0.0.0.0

# Root пользователь (администратор)
# ВАЖНО: Используйте ROOT_USERNAME, а не ROOT_EMAIL
# ROOT_EMAIL не поддерживается - система использует имя пользователя (username)
ROOT_USERNAME=root
ROOT_PASSWORD=ваш_пароль_здесь

# Секретный ключ для JWT токенов (рекомендуется изменить на случайную строку)
JWT_SECRET=default_secret